@{
    ViewData["Title"] = "GameVault";
}

@if (User.Identity?.IsAuthenticated == true)
{
    var total     = (int)(ViewData["Total"]     ?? 0);
    var playing   = (int)(ViewData["Playing"]   ?? 0);
    var completed = (int)(ViewData["Completed"] ?? 0);
    var backlog   = (int)(ViewData["Backlog"]   ?? 0);
    var dropped   = (int)(ViewData["Dropped"]   ?? 0);
    var recent    = ViewData["RecentGames"] as List<GameVault.Models.Game> ?? new();

    <h2 class="mb-4">Bem-vindo de volta 👋</h2>

    <!-- Estatísticas -->
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <div class="display-5 fw-bold">@total</div>
                    <div class="text-muted small">Total de jogos</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100 border-success">
                <div class="card-body">
                    <div class="display-5 fw-bold text-success">@playing</div>
                    <div class="text-muted small">A jogar</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100 border-info">
                <div class="card-body">
                    <div class="display-5 fw-bold text-info">@completed</div>
                    <div class="text-muted small">Concluídos</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <div class="display-5 fw-bold text-secondary">@backlog</div>
                    <div class="text-muted small">Na lista</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Adicionados recentemente -->
    @if (recent.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Adicionados recentemente</h4>
            <a asp-controller="Games" asp-action="Index" class="btn btn-sm btn-outline-primary">Ver todos</a>
        </div>
        <div class="row row-cols-2 row-cols-md-4 g-3">
            @foreach (var game in recent)
            {
                <div class="col">
                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.GameId"
                       class="text-decoration-none text-dark">
                        <div class="card h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(game.CoverUrl))
                            {
                                <img src="@game.CoverUrl" class="card-img-top"
                                     style="height:160px; object-fit:cover;" alt="@game.Title" />
                            }
                            else
                            {
                                <div class="bg-secondary d-flex align-items-center justify-content-center text-white"
                                     style="height:160px;">
                                    <small>Sem capa</small>
                                </div>
                            }
                            <div class="card-body p-2">
                                <p class="fw-semibold small mb-1 text-truncate">@game.Title</p>
                                <span class="badge @StatusBadgeClass(game.Status) small">@game.Status</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <p class="fs-5">A tua coleção está vazia.</p>
            <a asp-controller="Games" asp-action="Create" class="btn btn-primary">Adicionar o primeiro jogo</a>
        </div>
    }
}
else
{
    <!-- Landing page para visitantes -->
    <div class="text-center py-5">
        <h1 class="display-4 fw-bold mb-3">Game<span class="text-primary">Vault</span></h1>
        <p class="lead text-muted mb-4">
            A tua biblioteca pessoal de videojogos.<br />
            Regista, organiza e acompanha a tua coleção.
        </p>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg me-2">Criar conta</a>
        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg">Entrar</a>
    </div>
}

@functions {
    string StatusBadgeClass(GameVault.Models.GameStatus s) => s switch
    {
        GameVault.Models.GameStatus.Playing   => "bg-success",
        GameVault.Models.GameStatus.Completed => "bg-info text-dark",
        GameVault.Models.GameStatus.Dropped   => "bg-danger",
        _                                     => "bg-secondary"
    };
}
