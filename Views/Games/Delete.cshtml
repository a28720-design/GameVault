@model GameVault.Models.Game

@{
    ViewData["Title"] = "Apagar jogo";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-body text-center p-4">

                @if (!string.IsNullOrEmpty(Model.CoverUrl))
                {
                    <img src="@Model.CoverUrl" alt="@Model.Title"
                         class="rounded mb-3"
                         style="height:140px; object-fit:cover;" />
                }

                <h4 class="mb-1">@Model.Title</h4>
                <p class="text-muted mb-3">@Model.Platform?.Name</p>

                <p class="text-danger fw-semibold">
                    Tens a certeza que queres apagar este jogo? Esta ação não pode ser desfeita.
                </p>

                <form asp-action="Delete" class="d-flex gap-2 justify-content-center mt-3">
                    <input type="hidden" asp-for="GameId" />
                    <button type="submit" class="btn btn-danger">Sim, apagar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>
